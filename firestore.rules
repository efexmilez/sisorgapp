rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // ==================== USERS ====================
    // Users can read/write their own profile
    // Admins can read all users
    match /users/{userId} {
      // Allow users to read/write their own data
      allow read, write: if isOwner(userId) || isAdmin();
      
      // Allow creating new user profiles (after Firebase Auth signup)
      allow create: if isAuthenticated() 
        && request.resource.data.keys().hasAll(['full_name', 'email', 'role', 'kyc_status'])
        && request.resource.data.role == 'member'
        && request.resource.data.kyc_status == 'pending';
    }
    
    // ==================== CONTRIBUTIONS ====================
    // Members can read their own contributions, admins can read all
    match /contributions/{contributionId} {
      allow read: if isAuthenticated() 
        && (resource.data.user_id == request.auth.uid || isAdmin());
      
      // Only backend (via service account) can create contributions
      // Frontend should go through API endpoint
      allow create: if false; 
    }
    
    // Contribution balances - user reads own, admin reads all
    match /contribution_balances/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Only backend
    }
    
    // ==================== LOANS ====================
    // Members can read their own loans, admins can read all
    match /loans/{loanId} {
      allow read: if isAuthenticated() 
        && (resource.data.user_id == request.auth.uid || isAdmin());
      allow create: if false; // Only through API
      allow write: if isAdmin(); // Only admins can update loan status
    }
    
    // ==================== KYC DOCUMENTS ====================
    // KYC is handled through the backend API for security
    // The national_id_url and utility_bill_url are stored in users collection
    // with access controlled by the user document rules above
    
    // ==================== AUDIT LOGS ====================
    // Only admins can read audit logs
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if false; // Only backend
    }
    
    // ==================== SETTINGS ====================
    // Admins can read/write settings
    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }
    
    // ==================== DEFAULT DENY ====================
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}